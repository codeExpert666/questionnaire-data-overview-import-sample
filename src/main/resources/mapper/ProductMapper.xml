<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acme.questionnaire.mapper.ProductMapper">
    <select id="selectAllProducts" resultType="com.acme.questionnaire.ref.ProductRef">
        SELECT id,
               product_code,
               product_model
        FROM pq_product
    </select>
</mapper>
