<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acme.questionnaire.mapper.FeatureScoreMapper">
    <delete id="deleteByAnswerIds">
        DELETE FROM pq_answer_feature_score
        WHERE answer_id IN
        <foreach collection="answerIds" item="item" open="(" separator="," close=")">
            #{item}
        </foreach>
    </delete>

    <insert id="batchInsert">
        INSERT INTO pq_answer_feature_score (
            answer_id,
            feature_id,
            score,
            created_at,
            updated_at
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.answerId},
                #{item.featureId},
                #{item.score},
                CURRENT_TIMESTAMP,
                CURRENT_TIMESTAMP
            )
        </foreach>
    </insert>
</mapper>
