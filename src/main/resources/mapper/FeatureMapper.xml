<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acme.questionnaire.mapper.FeatureMapper">
    <select id="selectEnabledFeatures" resultType="com.acme.questionnaire.ref.FeatureRef">
        SELECT id,
               feature_code,
               feature_name,
               sort_no
        FROM pq_feature
        WHERE status = 1
        ORDER BY sort_no ASC, id ASC
    </select>
</mapper>
