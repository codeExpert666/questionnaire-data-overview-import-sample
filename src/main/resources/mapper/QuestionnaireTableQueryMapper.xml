<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.acme.questionnaire.mapper.QuestionnaireTableQueryMapper">
    <sql id="CommonAnswerProductFilters">
        <if test="criteria.questionnaireId != null">
            AND a.questionnaire_id LIKE CONCAT('%', #{criteria.questionnaireId}, '%')
        </if>
        <if test="criteria.productCode != null">
            AND p.product_code LIKE CONCAT('%', #{criteria.productCode}, '%')
        </if>
        <if test="criteria.productModel != null">
            AND p.product_model LIKE CONCAT('%', #{criteria.productModel}, '%')
        </if>
        <if test="criteria.answerTimeStart != null">
            AND a.answer_time &gt;= #{criteria.answerTimeStart}
        </if>
        <if test="criteria.answerTimeEnd != null">
            AND a.answer_time &lt;= #{criteria.answerTimeEnd}
        </if>
        <if test="criteria.romVersion != null">
            AND a.rom_version LIKE CONCAT('%', #{criteria.romVersion}, '%')
        </if>
        <if test="criteria.appVersion != null">
            AND a.app_version LIKE CONCAT('%', #{criteria.appVersion}, '%')
        </if>
        <if test="criteria.recommendScoreMin != null">
            AND a.recommend_score &gt;= #{criteria.recommendScoreMin}
        </if>
        <if test="criteria.recommendScoreMax != null">
            AND a.recommend_score &lt;= #{criteria.recommendScoreMax}
        </if>
        <if test="criteria.userCategory != null">
            AND a.user_category = #{criteria.userCategory}
        </if>
    </sql>

    <!--
        评分页仍以 pq_answer 为一行一问卷的查询粒度。
        featureId 和 featureScoreFilters 都通过 EXISTS 约束评分明细，不把 pq_answer_feature_score
        展开到主查询结果中，避免一份问卷因多个特性评分被重复计数或重复分页。
    -->
    <sql id="ScoreExistsFilters">
        <if test="criteria.featureId != null">
            AND EXISTS (
                SELECT 1
                FROM pq_answer_feature_score fs
                WHERE fs.answer_id = a.id
                  AND fs.feature_id = #{criteria.featureId}
            )
        </if>
        <include refid="FeatureScoreFilters"/>
    </sql>

    <sql id="FeatureScoreFilters">
        <if test="criteria.featureScoreFilters != null and criteria.featureScoreFilters.size > 0">
            <foreach collection="criteria.featureScoreFilters" item="scoreFilter">
                AND EXISTS (
                    SELECT 1
                    FROM pq_answer_feature_score fsf
                    WHERE fsf.answer_id = a.id
                      AND fsf.feature_id = #{scoreFilter.featureId}
                    <if test="scoreFilter.min != null">
                      AND fsf.score &gt;= #{scoreFilter.min}
                    </if>
                    <if test="scoreFilter.max != null">
                      AND fsf.score &lt;= #{scoreFilter.max}
                    </if>
                )
            </foreach>
        </if>
    </sql>

    <sql id="OpinionFilters">
        <if test="criteria.sentiment != null">
            AND o.sentiment_code = #{criteria.sentiment}
        </if>
        <if test="criteria.keyword != null">
            AND (
                a.feedback_text LIKE CONCAT('%', #{criteria.keyword}, '%')
                OR a.score_reason LIKE CONCAT('%', #{criteria.keyword}, '%')
                OR o.feedback_content_1 LIKE CONCAT('%', #{criteria.keyword}, '%')
                OR o.feedback_content_2 LIKE CONCAT('%', #{criteria.keyword}, '%')
            )
        </if>
    </sql>

    <sql id="OpinionFeatureFilter">
        <if test="criteria.featureId != null">
            AND o.feature_id = #{criteria.featureId}
        </if>
    </sql>

    <!--
        动态评分排序需要按指定 featureId 取出该问卷对应的一列分值。
        sort.alias 由 Service 生成，featureId 已校验为当前启用特性；XML 这里只负责拼接受控 join。
    -->
    <sql id="FeatureScoreSortJoins">
        <if test="featureScoreSorts != null and featureScoreSorts.size > 0">
            <foreach collection="featureScoreSorts" item="sort">
                LEFT JOIN pq_answer_feature_score ${sort.alias}
                    ON ${sort.alias}.answer_id = a.id
                   AND ${sort.alias}.feature_id = #{sort.featureId}
            </foreach>
        </if>
    </sql>

    <!--
        ORDER BY 使用 ${} 是因为列名/表达式不能用 #{ } 参数化。
        order.expression 和 order.direction 必须来自 Service 的白名单和方向校验，不能直接接收前端原值。
    -->
    <sql id="OrderBy">
        <if test="orderClauses != null and orderClauses.size > 0">
            ORDER BY
            <foreach collection="orderClauses" item="order" separator=",">
                ${order.expression} ${order.direction}
            </foreach>
        </if>
    </sql>

    <select id="countDataOverview" resultType="long">
        SELECT COUNT(*)
        FROM pq_opinion o
        INNER JOIN pq_answer a ON a.id = o.answer_id
        INNER JOIN pq_product p ON p.id = a.product_id
        LEFT JOIN pq_feature f ON f.id = o.feature_id
        WHERE 1 = 1
        <include refid="CommonAnswerProductFilters"/>
        <include refid="FeatureScoreFilters"/>
        <include refid="OpinionFilters"/>
        <include refid="OpinionFeatureFilter"/>
    </select>

    <select id="selectDataOverviewRows" resultType="com.acme.questionnaire.model.DataOverviewQueryRow">
        SELECT a.id AS answer_id,
               o.id AS opinion_id,
               a.questionnaire_id,
               p.product_model,
               p.product_code,
               a.answer_time,
               a.rom_version,
               a.app_version,
               a.feedback_text,
               a.score_reason,
               a.recommend_score,
               a.user_category,
               o.sentiment_code AS sentiment,
               f.feature_name,
               o.feedback_content_1,
               o.feedback_content_2
        FROM pq_opinion o
        INNER JOIN pq_answer a ON a.id = o.answer_id
        INNER JOIN pq_product p ON p.id = a.product_id
        LEFT JOIN pq_feature f ON f.id = o.feature_id
        <include refid="FeatureScoreSortJoins"/>
        WHERE 1 = 1
        <include refid="CommonAnswerProductFilters"/>
        <include refid="FeatureScoreFilters"/>
        <include refid="OpinionFilters"/>
        <include refid="OpinionFeatureFilter"/>
        <include refid="OrderBy"/>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 评分页总数：以 pq_answer 为基表统计问卷数，评分明细只通过 EXISTS 参与过滤。 -->
    <select id="countScores" resultType="long">
        SELECT COUNT(*)
        FROM pq_answer a
        INNER JOIN pq_product p ON p.id = a.product_id
        WHERE 1 = 1
        <include refid="CommonAnswerProductFilters"/>
        <include refid="ScoreExistsFilters"/>
    </select>

    <!--
        评分页当前页基础数据：一份问卷一行，只查固定字段。
        动态评分列在分页后由 selectFeatureScoresByAnswerIds 批量读取并写入响应行。
    -->
    <select id="selectScoreRows" resultType="com.acme.questionnaire.model.ScoreQueryRow">
        SELECT a.id AS answer_id,
               a.questionnaire_id,
               p.product_model,
               p.product_code,
               a.answer_time,
               a.rom_version,
               a.app_version,
               a.recommend_score,
               a.user_category
        FROM pq_answer a
        INNER JOIN pq_product p ON p.id = a.product_id
        <include refid="FeatureScoreSortJoins"/>
        WHERE 1 = 1
        <include refid="CommonAnswerProductFilters"/>
        <include refid="ScoreExistsFilters"/>
        <include refid="OrderBy"/>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countOpinions" resultType="long">
        SELECT COUNT(*)
        FROM pq_opinion o
        INNER JOIN pq_answer a ON a.id = o.answer_id
        INNER JOIN pq_product p ON p.id = a.product_id
        LEFT JOIN pq_feature f ON f.id = o.feature_id
        WHERE 1 = 1
        <include refid="CommonAnswerProductFilters"/>
        <include refid="OpinionFilters"/>
        <include refid="OpinionFeatureFilter"/>
    </select>

    <select id="selectOpinionRows" resultType="com.acme.questionnaire.model.OpinionQueryRow">
        SELECT o.id AS opinion_id,
               a.id AS answer_id,
               a.questionnaire_id,
               p.product_model,
               p.product_code,
               a.answer_time,
               a.recommend_score,
               a.user_category,
               o.opinion_seq,
               f.feature_name,
               o.sentiment_code AS sentiment,
               o.feedback_content_1,
               o.feedback_content_2,
               a.feedback_text,
               a.score_reason
        FROM pq_opinion o
        INNER JOIN pq_answer a ON a.id = o.answer_id
        INNER JOIN pq_product p ON p.id = a.product_id
        LEFT JOIN pq_feature f ON f.id = o.feature_id
        WHERE 1 = 1
        <include refid="CommonAnswerProductFilters"/>
        <include refid="OpinionFilters"/>
        <include refid="OpinionFeatureFilter"/>
        <include refid="OrderBy"/>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!--
        当前页动态评分回填查询：只针对已分页出的 answerId 批量读取，避免主查询发生一对多扩行。
        Service 会再按当前启用特性过滤，停用特性不会出现在本次响应动态列中。
    -->
    <select id="selectFeatureScoresByAnswerIds" resultType="com.acme.questionnaire.model.FeatureScoreCell">
        SELECT answer_id,
               feature_id,
               score
        FROM pq_answer_feature_score
        WHERE answer_id IN
        <foreach collection="answerIds" item="answerId" open="(" separator="," close=")">
            #{answerId}
        </foreach>
        ORDER BY answer_id ASC, feature_id ASC
    </select>
</mapper>
